class Solution(object):
    def removeDuplicates(self, nums):
        n=len(nums)
        j=i=0
        c=1
        while(j<n):
            if nums[i] != nums[j]:
                nums[i+1],nums[j]=nums[j],nums[i+1]
                i+=1
                c+=1
            j+=1
        return c
        
        
