class Solution(object):
    def moveZeroes(self, nums):
        n=len(nums)
        i=0
        j=i+1
        while i<n and j<n:
            if nums[i]!=0:
                i+=1
                j=i+1
            elif nums[i]==0 and nums[j]!=0:
                t=nums[i]
                nums[i]=nums[j]
                nums[j]=t
                i+=1
                j=i+1
            else:
                j+=1
            
        
