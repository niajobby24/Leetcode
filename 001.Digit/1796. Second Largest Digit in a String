class Solution(object):
    def secondHighest(self, s):
        mylist=set()
        for c in s:
            if c.isdigit():
                mylist.add(int(c))
        slist=sorted(mylist, reverse=True)
        for i in slist:
            if i==slist[0]:
                continue
            else:
                return i
        return -1
